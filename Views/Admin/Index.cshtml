@{
    ViewData["Title"] = "Admin Panel";

    var users = ViewBag.Users as List<My11CircleApp.Models.User>;
    var leagues = ViewBag.Leagues as List<My11CircleApp.Models.League>;
    var matches = ViewBag.Matches as List<My11CircleApp.Models.Match>;

    var leaderboard = users != null
        ? users.OrderByDescending(u => u.Wallet).ToList()
        : new List<My11CircleApp.Models.User>();
}

<style>
    .row {
        display: flex;
        gap: 20px;
    }

    .card {
        flex: 1;
        background: white;
        padding: 15px;
        border-radius: 6px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .top-actions {
        margin-bottom: 20px;
    }

        .top-actions a {
            padding: 10px 15px;
            margin-right: 10px;
            background: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

            .top-actions a:hover {
                background: #0056b3;
            }

    table {
        width: 100%;
        margin-top: 10px;
        border-collapse: collapse;
    }

    th, td {
        padding: 8px;
        border: 1px solid #ddd;
    }

    th {
        background: #333;
        color: white;
    }

    .action-container {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .inline-form {
        display: flex;
        gap: 5px;
        align-items: center;
        margin: 0;
    }

    .amount-box {
        width: 70px;
        padding: 5px;
        font-size: 13px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    /* buttons */
    .btn {
        padding: 6px 10px;
        font-size: 13px;
        border-radius: 5px;
        border: none;
        cursor: pointer;
        white-space: nowrap;
    }

    /* Add money */
    .btn-add {
        background-color: #28a745;
        color: white;
    }

    /* Reset */
    .btn-reset {
        background-color: #dc3545;
        color: white;
    }

    /* hover */
    .btn:hover {
        opacity: 0.9;
    }
</style>

<h2>Admin Panel</h2>

<!-- 🔹 TOP BUTTONS -->
<div class="top-actions">
    <a href="/Admin/AddMatch">➕ Add Match</a>
    <a href="/Admin/AddResult">🏆 Add Result</a>
   
</div>

<!-- 🔹 ROW: 3 COLUMNS -->
<div class="row">

    <!-- CREATE PLAYER -->
    <div class="card">
        <h4>Create Player</h4>
        <form method="post" action="/Admin/CreateUser">
            <input type="text" name="name" placeholder="Name" required /><br />
            <input type="email" name="email" placeholder="Email" required /><br />
            <input type="password" name="password" placeholder="Password" required /><br />
            <select name="role">
                <option value="user">Player</option>
                <option value="admin">Admin</option>
            </select><br /><br />
            <button type="submit">Add</button>
        </form>
    </div>

    <!-- ADD MONEY -->
    <div class="card">
        <h4>Add Money</h4>
        <form method="post" action="/Admin/AddMoney">
            <select name="userId">
                @if (users != null)
                {
                    foreach (var u in users)
                    {
                        <option value="@u.Id">@u.Name (₹@u.Wallet)</option>
                    }
                }
            </select><br />
            <input type="number" name="amount" placeholder="Amount" required /><br /><br />
            <button type="submit">Add</button>
        </form>
    </div>

    <!-- ADD LEAGUE -->
    <div class="card">
        <h4>Add League</h4>
        <form method="post" action="/Admin/AddLeague">
            <input type="text" name="name" placeholder="League Name" required /><br />
            <input type="text" name="description" placeholder="Description" required /><br /><br />
            <button type="submit">Add</button>
        </form>
    </div>

</div>

<hr />

<h3>Users</h3>

<table class="table">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Wallet</th>
        <th>Action</th>
    </tr>

    @if (ViewBag.Users != null)
    {
        foreach (var u in ViewBag.Users)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Name</td>
                <td>@u.Email</td>
                <td>₹@u.Wallet</td>

                <td>
                    <div class="action-container">

                        <!-- 💰 Add Money -->
                        <form method="post" action="/Admin/AddMoney" class="inline-form">
                            <input type="hidden" name="userId" value="@u.Id" />
                            <input type="number" name="amount" placeholder="₹" class="amount-box" required />
                            <button type="submit" class="btn btn-add">
                                Add Money
                            </button>
                        </form>

                        <!-- 🔐 Reset Password -->
                        <form method="post" action="/Admin/ResetPassword" class="inline-form">
                            <input type="hidden" name="userId" value="@u.Id" />
                            <button type="submit"
                                    onclick="return confirm('Reset password to 1234?')"
                                    class="btn btn-reset">
                                Reset Password
                            </button>
                        </form>

                    </div>
                </td>
            </tr>
        }
    }
</table>

<!-- 🔹 LEADERBOARD -->
<h3>Leaderboard</h3>
<table>
    <tr>
        <th>Rank</th>
        <th>Player</th>
        <th>Wallet</th>
    </tr>

    @{
        int rank = 1;
    }

    @foreach (var u in leaderboard)
    {
        <tr>
            <td>@rank</td>
            <td>@u.Name</td>
            <td>₹@u.Wallet</td>
        </tr>
        rank++;
    }
</table>

<hr />

<!-- 🔹 MATCHES -->
<h3>Matches</h3>

<table class="table">
    <tr>
        <th>Id</th>
        <th>League</th>
        <th>Description</th>
        <th>Date</th>
        <th>Status</th>
        <th>Fee</th>
        <th>Action</th>
    </tr>

    @if (ViewBag.Matches != null)
    {
        foreach (var m in ViewBag.Matches)
        {
            <tr>
                <td>@m.Id</td>
                <td>@m.LeagueId</td>
                <td>@(m.Description ?? "N/A")</td>

                <!-- ✅ Then Date -->
                <td>@m.MatchDate.ToString("dd-MM-yyyy")</td>
                <td>@m.Status</td>
                <td>₹@m.EntryFee</td>

                <td>
                    <a href="/Admin/EditMatch?matchId=@m.Id" class="btn btn-primary">
                        Edit Match
                    </a>

                    <a href="/Admin/EditResult?matchId=@m.Id" class="btn btn-warning">
                        Edit Result
                    </a>
                </td>
            </tr>
        }
    }
</table>