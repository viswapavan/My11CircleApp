@inject My11CircleApp.Data.AppDbContext _context
<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
        }

        h2 {
            margin-bottom: 15px;
        }

        /* ROW + CARD */
        .row {
            display: flex;
            gap: 20px;
        }

        .card {
            flex: 1;
            background: #fff;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.08);
        }

        /* TOP BUTTONS */
        .top-actions {
            margin-bottom: 20px;
        }

            .top-actions a {
                padding: 10px 16px;
                margin-right: 10px;
                background: #007bff;
                color: #fff;
                text-decoration: none;
                border-radius: 6px;
                font-weight: 500;
            }

                .top-actions a:hover {
                    background: #0056b3;
                }

        /* 🔥 INPUT STYLING */
        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 6px;
            margin-bottom: 12px;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: 14px;
            transition: 0.2s;
        }

            /* Focus effect */
            input:focus, select:focus {
                border-color: #007bff;
                outline: none;
                box-shadow: 0 0 5px rgba(0,123,255,0.3);
            }

        /* 🔥 BUTTON STYLE */
        button {
            width: 100%;
            padding: 10px;
            background: #28a745;
            border: none;
            color: white;
            border-radius: 6px;
            font-size: 15px;
            cursor: pointer;
            transition: 0.2s;
        }

            button:hover {
                background: #218838;
            }

        /* TABLE */
        table {
            width: 100%;
            margin-top: 10px;
            border-collapse: collapse;
            background: #fff;
        }

        th, td {
            padding: 10px;
            border: 1px solid #ddd;
        }

        th {
            background: #343a40;
            color: white;
        }

        tr:hover {
            background: #f1f1f1;
        }
    </style>
    <meta charset="utf-8" />
    <title>My11Circle App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f5f5f5;
        }

        .navbar {
            padding: 10px;
        }
    </style>
</head>

<body>

    @{
        var userId = Context.Session.GetInt32("UserId");
        decimal wallet = 0;

        if (userId != null)
        {
            wallet = _context.Users
            .Where(u => u.Id == userId)
            .Select(u => u.Wallet)
            .FirstOrDefault();
        }
    }

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">🏏 My11Circle</a>

            <div class="d-flex align-items-center">

                @if (userId != null)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-light">Dashboard</a>

                    @if (Context.Session.GetString("Role") == "admin")
                    {
                        <a asp-controller="Admin" asp-action="Index" class="btn btn-warning me-2">Admin</a>
                    }

                    <span class="text-white me-3">
                        👤 @Context.Session.GetString("UserName")
                    </span>

                    <span class="text-warning me-3 fw-bold">
                        💰 ₹@wallet
                    </span>

                    <a href="/Wallet/Index" class="btn btn-info me-2">Wallet</a>

                    <a href="/Account/Logout" class="btn btn-danger">Logout</a>
                }
                else
                {
                    <a href="/Account/Login" class="btn btn-primary">Login</a>
                }

            </div>

        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>